# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=20

# AI providers — adapter selection
AI_LLM_PROVIDER=bedrock
AI_EMBEDDING_PROVIDER=bedrock

# Amazon Bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# PostgreSQL + pgvector
DB_HOST=localhost
DB_PORT=5432
DB_NAME=experience_rag
DB_USER=postgres
DB_PASSWORD=postgres

# Experience data source (markdown | database)
EXPERIENCE_SOURCE=markdown

# Cache provider (memory | redis)
CACHE_PROVIDER=memory
LANDING_CACHE_TTL=3600
