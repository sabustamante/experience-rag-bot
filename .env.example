# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=20

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Adapter selection: bedrock | openai (openai adapter not yet implemented)
AI_LLM_PROVIDER=bedrock
AI_EMBEDDING_PROVIDER=bedrock

# ─── Amazon Bedrock ───────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ─── PostgreSQL + pgvector ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=experience_rag
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Experience Data ──────────────────────────────────────────────────────────
# Source adapter: markdown | database
EXPERIENCE_SOURCE=markdown

# ─── Cache ────────────────────────────────────────────────────────────────────
# Cache adapter: memory | redis (redis adapter not yet implemented)
CACHE_PROVIDER=memory
LANDING_CACHE_TTL=3600

# ─── Chat System Prompt ────────────────────────────────────────────────────────
# Optional — appended to the default system prompt at startup.
# Use it to customize language, tone, or persona without touching code.
# Examples:
#   Always respond in Spanish.
#   Be concise. Use bullet points when listing multiple items.
#   Adopt a friendly, informal tone.
# SYSTEM_PROMPT_APPEND=
