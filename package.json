{
  "name": "experience-rag-bot",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .prettierignore",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,cjs,mjs}": "prettier --write",
    "**/*.{json,md}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
